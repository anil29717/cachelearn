# Copy to `.env` in the repo root for `docker compose` (docker-compose.yml reads this file).

MYSQL_ROOT_PASSWORD=change_this_to_a_long_random_secret
MYSQL_DATABASE=course_platform

# When using root in MySQL, set DB_PASSWORD equal to MYSQL_ROOT_PASSWORD.
DB_USER=root
DB_PASSWORD=change_this_to_a_long_random_secret
DB_NAME=course_platform

JWT_SECRET=change_this_to_a_long_random_jwt_secret
FRONTEND_URL=http://localhost:4000
BACKEND_URL=http://localhost:8080
CONTACT_RECEIVER_EMAIL=admin@local.invalid
