# Frontend production environment
# Point this to your deployed backend origin when frontend and backend are not same-origin.
VITE_BACKEND_URL=https://api.yourdomain.com
# Idle logout (minutes); should match backend SESSION_IDLE_MINUTES
VITE_SESSION_IDLE_MINUTES=30
# Optional HTTPS embed only — leave unset to disable chat widget
# VITE_EMBED_CHAT_URL=https://chat.example.com/embed
