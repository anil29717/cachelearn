# Do not use 6000 — Chrome blocks it (ERR_UNSAFE_PORT). Use 8080 or similar.
PORT=8080
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=course_platform
JWT_SECRET=

# Frontend/Backend URLs
FRONTEND_URL=http://localhost:4000
BACKEND_URL=http://localhost:8080

# Contact form destination
CONTACT_RECEIVER_EMAIL=

# Optional: restrict API access to office/VPN public IPs or CIDR ranges
# Example: ALLOWED_NETWORKS=203.0.113.10,198.51.100.0/24
ALLOWED_NETWORKS=

# Set to 1 when running behind a reverse proxy/load balancer
TRUST_PROXY=0

# Optional: native TLS (otherwise terminate HTTPS at nginx / your load balancer)
# HTTPS_CERT_PATH=/path/to/fullchain.pem
# HTTPS_KEY_PATH=/path/to/privkey.pem

# Optional: when running seed, keep all other users (skip cleanup)
# SEED_KEEP_ALL=0

# Optional: seed users when DB is empty but seed-users.json exists without first-run passwords
# SEED_ADMIN_PASSWORD=
# SEED_EMPLOYEE_PASSWORD=