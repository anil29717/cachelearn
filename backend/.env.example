# Do not use 6000 ? Chrome blocks it (ERR_UNSAFE_PORT). Use 8080 or similar.
PORT=8080
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=course_platform
JWT_SECRET=

# Session: production defaults to 8h JWT + 30m idle logout (frontend)
# JWT_EXPIRES_IN=8h
# SESSION_IDLE_MINUTES=30

# Frontend/Backend URLs
FRONTEND_URL=http://localhost:4000
BACKEND_URL=http://localhost:8080

# Contact form destination
CONTACT_RECEIVER_EMAIL=

# Optional: restrict API access to office/VPN public IPs or CIDR ranges
# Example: ALLOWED_NETWORKS=203.0.113.10,198.51.100.0/24
ALLOWED_NETWORKS=

# Set to 1 when Node is behind a reverse proxy on the same host (127.0.0.1 / ::1).
# Trust proxy uses Express "loopback" preset only; do not enable for direct internet exposure without a proxy.
TRUST_PROXY=0

# Automation / AppScan: disable all API rate limits (login, /api, uploads). Remove on public prod.
DISABLE_RATE_LIMIT=1

# Optional: native TLS (otherwise terminate HTTPS at nginx / your load balancer).
# Local dev: run `npm run generate-cert` first — do not commit backend/certs/*.pem.
# Paths must resolve under cwd unless HTTPS_ARTIFACT_ROOT is set (absolute path to allowed cert directory).
# HTTPS_CERT_PATH=./certs/localhost-cert.pem
# HTTPS_KEY_PATH=./certs/localhost-key.pem
# HTTPS_ARTIFACT_ROOT=

# Optional: when running seed, keep all other users (skip cleanup)
# SEED_KEEP_ALL=0

# Demo / AppScan users (npm run seed:demo) — set in .env only; never commit real values
SEED_ADMIN_PASSWORD=
SEED_EMPLOYEE_PASSWORD=
# Do not commit scripts/seed-demo-hardcoded.mjs or other local *-secrets* / *-local* copies